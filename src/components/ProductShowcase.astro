---
import imgMain from "../assets/images/polera.jpeg";
---

<section id="products" class="product-showcase-elite">
  <!-- Dynamic Background Text -->
  <div class="bg-parallax-text" id="parallax-text-elite">COLLECTION</div>

  <div class="container-elite">
    <div class="visual-side animate-reveal-elite">
      <div class="image-wrapper scroll-zoom-elite">
        <img
          src={imgMain.src}
          alt="Polera Misiones"
          class="featured-product-img"
        />
        <div class="image-decoration"></div>
      </div>
    </div>

    <div class="info-side">
      <div class="content-wrapper">
        <div class="badge-premium animate-reveal-elite">EDICIÓN LIMITADA</div>

        <h2 class="title-elite animate-reveal-elite">
          <span class="line">POLERA</span>
          <span class="line highlight">MISIONES HDM</span>
        </h2>

        <p class="description-elite animate-reveal-elite">
          "No solo hijos, también llamados". Una prenda diseñada para impactar,
          con un propósito claro y la máxima calidad en cada detalle.
        </p>

        <div class="specs-grid-elite">
          <div class="spec-item animate-reveal-elite">
            <span class="label">Fit</span>
            <span class="val">Oversized</span>
          </div>
          <div class="spec-item animate-reveal-elite">
            <span class="label">Material</span>
            <span class="val">Cotton 100%</span>
          </div>
          <div class="spec-item animate-reveal-elite">
            <span class="label">Bordado</span>
            <span class="val">Relieve 3D</span>
          </div>
        </div>

        <div class="price-action-row animate-reveal-elite">
          <div class="price-display">
            <span class="symbol">S/</span>
            <span class="val">49.00</span>
          </div>
          <button
            class="btn-elite-whatsapp"
            id="buy-whatsapp"
            data-name="Polera Misiones HDM (Edición Especial)"
            data-price="49.00"
            data-img={imgMain.src}
          >
            <span>PEDIR AHORA</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
          </button>
        </div>

        <p class="stock-status animate-reveal-elite">
          ● Pocas unidades disponibles
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .product-showcase-elite {
    background: #ffffff;
    padding: 12rem 0;
    position: relative;
    overflow: hidden;
  }

  .bg-parallax-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 25vw;
    font-weight: 900;
    color: rgba(0, 0, 0, 0.02);
    z-index: 0;
    white-space: nowrap;
    letter-spacing: -1vw;
  }

  .container-elite {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    align-items: center;
    position: relative;
    z-index: 10;
  }

  .image-wrapper {
    position: relative;
    background: #f8f8f8;
    padding: 4rem;
    border-radius: 4rem;
    overflow: hidden;
  }

  .featured-product-img {
    width: 100%;
    height: auto;
    mix-blend-mode: multiply;
    transform: scale(1);
    transition: transform 1s ease;
  }

  .badge-premium {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: #111;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 2px;
    border-radius: 4px;
    margin-bottom: 2rem;
  }

  .title-elite {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -3px;
    margin-bottom: 2.5rem;
  }

  .title-elite .highlight {
    color: var(--color-primary);
  }

  .description-elite {
    font-size: 1.2rem;
    color: #666;
    line-height: 1.6;
    margin-bottom: 4rem;
    max-width: 500px;
  }

  .specs-grid-elite {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 5rem;
  }

  .spec-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .spec-item .label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    color: #aaa;
    letter-spacing: 1px;
  }

  .spec-item .val {
    font-size: 1.1rem;
    font-weight: 800;
    color: #111;
  }

  .price-action-row {
    display: flex;
    align-items: center;
    gap: 3rem;
    margin-bottom: 2rem;
  }

  .price-display {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .price-display .symbol {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .price-display .val {
    font-size: 4rem;
    font-weight: 950;
    color: #111;
    letter-spacing: -2px;
  }

  .btn-elite-whatsapp {
    flex: 1;
    max-width: 300px;
    height: 70px;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 100px;
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 1px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    transition: all 0.4s ease;
  }

  .btn-elite-whatsapp:hover {
    background: var(--color-primary);
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(85, 153, 138, 0.3);
  }

  .stock-status {
    font-size: 0.8rem;
    font-weight: 700;
    color: #ff3366;
    letter-spacing: 1px;
  }

  @media (max-width: 1024px) {
    .product-showcase-elite {
      padding: 4rem 0; /* Reduced from 6rem */
    }
    .container-elite {
      grid-template-columns: 1fr;
      gap: 3rem; /* Reduced from 4rem */
      padding: 0 1.5rem;
      text-align: center;
    }
    .image-wrapper {
      padding: 1.5rem; /* More compact */
      border-radius: 2rem;
    }
    .description-elite {
      margin: 0 auto 2.5rem;
      font-size: 1.1rem;
    }
    .specs-grid-elite {
      gap: 1rem;
      margin-bottom: 3rem;
    }
    .price-action-row {
      flex-direction: column;
      gap: 1.5rem;
    }
    .price-display .val {
      font-size: 3rem;
    }
    .btn-elite-whatsapp {
      width: 100%;
      max-width: 100%;
      height: 60px; /* Slightly shorter */
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Background Text Parallax
  gsap.to("#parallax-text-elite", {
    scrollTrigger: {
      trigger: ".product-showcase-elite",
      start: "top bottom",
      end: "bottom top",
      scrub: 2,
    },
    xPercent: -20,
    ease: "none",
  });

  // Reveal Animations
  const eliteReveals = document.querySelectorAll(".animate-reveal-elite");
  eliteReveals.forEach((el) => {
    gsap.from(el, {
      scrollTrigger: {
        trigger: el,
        start: "top 90%",
      },
      y: 40,
      opacity: 0,
      duration: 1,
      ease: "power3.out",
    });
  });

  // Image Zoom
  gsap.to(".featured-product-img", {
    scrollTrigger: {
      trigger: ".product-showcase-elite",
      start: "top bottom",
      end: "bottom top",
      scrub: true,
    },
    scale: 1.1,
  });

  // Modal logic
  document.getElementById("buy-whatsapp")?.addEventListener("click", (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    if (window.openProductModal) {
      window.openProductModal({
        name: btn.dataset.name,
        price: parseFloat(btn.dataset.price || "0"),
        image: btn.dataset.img,
        styles: ["Sin Cierre", "Con Cierre"],
        colors: [{ name: "Negro Original", hex: "#111" }],
      });
    }
  });
</script>
