---

<div class="cart-drawer" id="cart-drawer">
  <div class="cart-header">
    <h3>Tu Pedido</h3>
    <button id="close-cart" class="close-cart-btn">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="18" y1="6" x2="6" y2="18"></line><line
          x1="6"
          y1="6"
          x2="18"
          y2="18"></line></svg
      >
    </button>
  </div>

  <div class="cart-body">
    <div id="cart-items">
      <!-- Items will be injected here -->
      <p class="empty-msg">Tu carrito está vacío</p>
    </div>
  </div>

  <div class="cart-footer">
    <div class="total">
      <span>Total:</span>
      <span id="cart-total">S/ 0.00</span>
    </div>
    <button class="btn-whatsapp-full" id="whatsapp-checkout">
      Finalizar pedido por WhatsApp
    </button>
  </div>
</div>

<button class="cart-floating-btn" id="open-cart">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    ><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"
    ></circle><path
      d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
    ></path></svg
  >
  <span class="cart-count" id="cart-count">0</span>
</button>

<style>
  .cart-floating-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 65px;
    height: 65px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    z-index: 3000;
    box-shadow: 0 10px 30px rgba(85, 153, 138, 0.4);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cart-floating-btn:hover {
    transform: scale(1.1);
  }

  .cart-count {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--color-accent);
    color: white;
    width: 25px;
    height: 25px;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 800;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 2px solid white;
  }

  .cart-drawer {
    position: fixed;
    top: 0;
    right: -450px;
    width: 450px;
    height: 100vh;
    background: white;
    z-index: 4000;
    box-shadow: -20px 0 50px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    transition: 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cart-drawer.open {
    right: 0;
  }

  .cart-header {
    padding: 2.5rem;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cart-header h3 {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -0.5px;
    margin: 0;
  }

  .close-cart-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #f5f5f5;
    border: none;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .close-cart-btn:hover {
    background: #000;
    color: #fff;
    transform: rotate(90deg);
  }

  .cart-body {
    flex: 1;
    padding: 2rem;
    overflow-y: auto;
  }

  /* Cart Item Styles */
  :global(.cart-item) {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #f5f5f5;
    align-items: center;
  }

  :global(.cart-item-img) {
    width: 80px;
    height: 80px;
    background: #f9f9f9;
    border-radius: 12px;
    object-fit: contain;
    padding: 0.5rem;
  }

  :global(.cart-item-info) {
    flex: 1;
  }

  :global(.cart-item-name) {
    font-weight: 800;
    font-size: 0.95rem;
    line-height: 1.3;
    margin-bottom: 0.4rem;
    display: block;
  }

  :global(.cart-item-price) {
    font-weight: 700;
    color: var(--color-primary);
    font-size: 1rem;
  }

  :global(.cart-item-remove) {
    background: none;
    border: none;
    color: #ff4d4d;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    padding: 0.5rem;
    transition: opacity 0.3s;
  }

  :global(.cart-item-remove:hover) {
    opacity: 0.6;
  }

  .empty-msg {
    text-align: center;
    color: #999;
    margin-top: 5rem;
    font-weight: 600;
  }

  .cart-footer {
    padding: 2.5rem;
    border-top: 1px solid #f0f0f0;
    background: #fff;
  }

  .total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }

  .total span:first-child {
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 1px;
  }

  .total #cart-total {
    font-size: 2.2rem;
    font-weight: 950;
    color: #111;
    letter-spacing: -1px;
  }

  .btn-whatsapp-full {
    width: 100%;
    background: #000;
    color: white;
    padding: 1.5rem;
    border-radius: 100px;
    border: none;
    font-weight: 900;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-whatsapp-full:hover {
    background: #25d366;
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(37, 211, 102, 0.2);
  }

  @media (max-width: 768px) {
    .cart-drawer {
      width: 100%;
    }
    .cart-floating-btn {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 55px;
      height: 55px;
      z-index: 5000;
    }
  }
</style>

<script>
  // Simple Cart State
  let cart = [];
  const openBtn = document.getElementById("open-cart");
  const closeBtn = document.getElementById("close-cart");
  const drawer = document.getElementById("cart-drawer");
  const checkoutBtn = document.getElementById("whatsapp-checkout");

  openBtn?.addEventListener("click", () => drawer?.classList.add("open"));
  closeBtn?.addEventListener("click", () => drawer?.classList.remove("open"));

  // Function to add to cart (can be called from other components)
  (window as any).addToCart = (product) => {
    cart.push(product);
    updateCartUI();
    drawer?.classList.add("open");

    // Alerta premium de éxito
    if ((window as any).showToast) {
      (window as any).showToast(`¡${product.name} añadido!`, "success");
    }
  };

  function updateCartUI() {
    const itemsEl = document.getElementById("cart-items");
    const totalEl = document.getElementById("cart-total");
    const count = cart.length;

    // Actualizar TODOS los contadores en el sitio (Navbar, Mobile Nav, Floating)
    const allCounters = document.querySelectorAll(
      ".cart-count, .cart-badge, #cart-count",
    );
    allCounters.forEach((el) => {
      (el as HTMLElement).innerText = count.toString();
      // Opcional: Ocultar si es 0
      (el as HTMLElement).style.display = count === 0 ? "none" : "flex";
    });

    if (itemsEl) {
      if (cart.length === 0) {
        itemsEl.innerHTML = '<p class="empty-msg">Tu carrito está vacío</p>';
      } else {
        itemsEl.innerHTML = cart
          .map(
            (item, index) => `
          <div class="cart-item">
            <img src="${item.image}" class="cart-item-img" alt="${item.name}" />
            <div class="cart-item-info">
              <span class="cart-item-name">${item.name}</span>
              <span class="cart-item-price">S/ ${item.price.toFixed(2)}</span>
            </div>
            <button onclick="window.removeFromCart(${index})" class="cart-item-remove">Eliminar</button>
          </div>
        `,
          )
          .join("");
      }
    }

    const total = cart.reduce((acc, item) => acc + item.price, 0);
    if (totalEl) totalEl.innerText = `S/ ${total.toFixed(2)}`;
  }

  (window as any).removeFromCart = (index) => {
    cart.splice(index, 1);
    updateCartUI();
  };

  checkoutBtn?.addEventListener("click", () => {
    if (cart.length === 0) {
      if ((window as any).showToast)
        (window as any).showToast("Tu carrito está vacío", "error");
      return;
    }

    const phoneNumber = "51913882945";
    let message = "¡Hola! Quiero realizar el siguiente pedido:\n\n";
    cart.forEach((item) => {
      message += `- ${item.name} (S/ ${item.price})\n`;
    });
    const total = cart.reduce((acc, item) => acc + item.price, 0);
    message += `\n*Total: S/ ${total.toFixed(2)}*`;

    window.open(
      `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`,
      "_blank",
    );
  });
</script>
