---
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="logo">
        <a href="/">MISIONES<span>HDM</span></a>
      </div>
      <p>Redefining modern streetwear through a lens of futurism and quality. Designed for those who define their own path.</p>
    </div>

    <div class="footer-links">
      <div class="link-group">
        <h4>Colección</h4>
        <ul>
          <li><a href="#">T-Shirts</a></li>
          <li><a href="#">Jackets</a></li>
          <li><a href="#">Pants</a></li>
          <li><a href="#">Accessories</a></li>
        </ul>
      </div>

      <div class="link-group">
        <h4>Soporte</h4>
        <ul>
          <li><a href="#">Envios</a></li>
          <li><a href="#">Devoluciones</a></li>
          <li><a href="#">Tallas</a></li>
          <li><a href="#">Contacto</a></li>
        </ul>
      </div>

      <div class="link-group">
        <h4>Social</h4>
        <ul>
          <li><a href="#">Instagram</a></li>
          <li><a href="#">TikTok</a></li>
          <li><a href="#">Twitter</a></li>
          <li><a href="#">Discord</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-content">
      <p>&copy; 2026 MISIONES HDM. Todos los derechos reservados.</p>
      <div class="footer-legal">
        <a href="#">Términos y Condiciones</a>
        <a href="#">Política de Privacidad</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #f0f0f0;
    padding: var(--spacing-xl) 0 2rem;
    border-top: 1px solid #ddd;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4rem;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .footer-brand .logo {
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: 2px;
  }

  .footer-brand p {
    color: var(--color-text-light);
    line-height: 1.6;
    max-width: 300px;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .link-group h4 {
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .link-group ul {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    list-style: none;
    padding: 0;
  }

  .link-group a {
    color: var(--color-text-light);
    transition: var(--transition-smooth);
    font-size: 0.95rem;
    text-decoration: none;
  }

  .link-group a:hover {
    color: var(--color-primary);
    padding-left: 5px;
  }

  .footer-bottom {
    border-top: 1px solid #ddd;
    padding-top: 2rem;
  }

  .footer-bottom-content {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-text-light);
    font-size: 0.85rem;
  }

  .footer-legal {
    display: flex;
    gap: 2rem;
  }

  .footer-legal a:hover {
    color: var(--color-white);
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-brand p {
      margin: 0 auto;
    }

    .footer-links {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-bottom-content {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }
  }
</style>
