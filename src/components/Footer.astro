---
const socialLinks = [
  { name: "Facebook", url: "#", icon: "facebook" },
  { name: "Instagram", url: "#", icon: "instagram" },
  { name: "YouTube", url: "#", icon: "youtube" },
  { name: "TikTok", url: "#", icon: "tiktok" },
];
---

<footer class="footer">
  <div class="footer-bg-blur"></div>
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand animate-reveal">
        <div class="brand-wrapper">
          <img src="/logo.png" alt="Logo HDM" class="footer-logo-icon" />
          <a href="/" class="logo">TIENDA<span>HDM</span></a>
        </div>
        <p class="tagline">
          Viste con elegancia, vive con propósito. Streetwear premium inspirado
          en la fe.
        </p>
      </div>

      <div class="footer-socials animate-reveal">
        <p class="social-title">SÍGUENOS</p>
        <div class="social-icons">
          <a href="#" aria-label="Facebook" class="social-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
              ></path></svg
            >
          </a>
          <a href="#" aria-label="Instagram" class="social-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg
            >
          </a>
          <a href="#" aria-label="YouTube" class="social-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"
              ></path><polygon
                points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"
              ></polygon></svg
            >
          </a>
          <a href="#" aria-label="TikTok" class="social-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg
            >
          </a>
        </div>
      </div>
    </div>

    <div class="footer-divider animate-divider"></div>

    <div class="footer-credits">
      <div class="creator animate-reveal">
        <span>Diseñado por</span>
        <a
          href="https://github.com/percyby2000"
          target="_blank"
          rel="noopener noreferrer"
          class="github-link"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
            ></path></svg
          >
          percyby2000
        </a>
      </div>

      <div class="cta-wrapper animate-reveal">
        <a href="https://wa.me/913882945" class="cta-link">
          <span class="cta-text">¿Quieres un sitio web como este?</span>
          <span class="cta-sub">Crea tu sitio web con nosotros →</span>
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>
        &copy; {new Date().getFullYear()} TIENDA HDM. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Reveal animations
  const reveals = document.querySelectorAll(".animate-reveal");
  reveals.forEach((el, i) => {
    gsap.fromTo(
      el,
      {
        opacity: 0,
        y: 50,
        filter: "blur(10px)",
      },
      {
        opacity: 1,
        y: 0,
        filter: "blur(0px)",
        duration: 1.2,
        delay: i * 0.1,
        ease: "expo.out",
        scrollTrigger: {
          trigger: el,
          start: "top 90%",
          toggleActions: "play none none none",
        },
      },
    );
  });

  // Divider expansion
  gsap.fromTo(
    ".animate-divider",
    { scaleX: 0, opacity: 0 },
    {
      scaleX: 1,
      opacity: 1,
      duration: 1.5,
      ease: "power4.inOut",
      scrollTrigger: {
        trigger: ".animate-divider",
        start: "top 95%",
      },
    },
  );

  // Parallax background effect
  gsap.to(".footer-bg-blur", {
    y: -100,
    scrollTrigger: {
      trigger: ".footer",
      start: "top bottom",
      end: "bottom top",
      scrub: true,
    },
  });
</script>

<style>
  .footer {
    background: #050505;
    color: #ffffff;
    padding: 8rem 0 2rem;
    position: relative;
    overflow: hidden;
  }

  .footer-bg-blur {
    position: absolute;
    top: -50%;
    left: -10%;
    width: 120%;
    height: 150%;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(85, 153, 138, 0.05) 0%,
      transparent 70%
    );
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .footer-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 3rem;
    margin-bottom: 6rem;
  }

  .footer-brand {
    flex: 1;
    min-width: 300px;
  }

  .brand-wrapper {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1.5rem;
  }

  .footer-logo-icon {
    width: 45px;
    height: 45px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(85, 153, 138, 0.3));
    transition: transform 0.3s ease;
  }

  .brand-wrapper:hover .footer-logo-icon {
    transform: rotate(-10deg) scale(1.1);
  }

  .logo {
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: -2px;
    color: #fff;
    text-decoration: none;
    display: inline-block;
    margin: 0;
  }

  .logo span {
    color: var(--color-primary);
  }

  .tagline {
    color: #777;
    max-width: 400px;
    line-height: 1.8;
    font-size: 1.1rem;
    font-weight: 300;
  }

  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .social-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.3rem;
    color: #444;
    text-transform: uppercase;
  }

  .social-icons {
    display: flex;
    gap: 1.5rem;
  }

  .social-link {
    color: #666;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .social-link:hover {
    color: #fff;
    background: var(--color-primary);
    transform: translateY(-8px) rotate(8deg);
    border-color: var(--color-primary);
    box-shadow: 0 15px 30px rgba(85, 153, 138, 0.3);
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    margin-bottom: 4rem;
    transform-origin: left;
  }

  .footer-credits {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 3rem;
    margin-bottom: 6rem;
  }

  .creator {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1rem;
    color: #555;
  }

  .github-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #ccc;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 8px;
  }

  .github-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  .cta-wrapper {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.03) 0%,
      rgba(255, 255, 255, 0.01) 100%
    );
    padding: 2rem 3rem;
    border-radius: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(10px);
  }

  .cta-wrapper:hover {
    border-color: var(--color-primary);
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .cta-link {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cta-text {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    color: #555;
    font-family: var(--font-mono);
  }

  .cta-sub {
    font-size: 1.4rem;
    font-weight: 800;
    color: #fff;
    transition: color 0.3s ease;
  }

  .cta-wrapper:hover .cta-sub {
    color: var(--color-primary);
  }

  .footer-bottom {
    text-align: center;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    color: #333;
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 6rem 0 3rem;
    }

    .footer-main {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer-credits {
      flex-direction: column;
      text-align: center;
      gap: 3rem;
    }

    .cta-wrapper {
      width: 100%;
      padding: 2rem;
    }

    .logo {
      font-size: 2rem;
    }

    .cta-sub {
      font-size: 1.2rem;
    }
  }
</style>
