---
import imgPolera from "../assets/images/espaldar.svg";
---

<section class="premium-showcase-v2" id="threed-section">
  <div class="container">
    <div class="showcase-content-grid">
      <div class="text-side">
        <div class="reveal-stagger">
          <span class="eyebrow-accent">Ingeniería Textil</span>
          <h2 class="display-title">
            MOVIMIENTO <br />
            <span class="outline-display">SIN LÍMITES</span>
          </h2>
          <p class="description-text">
            Diseñamos prendas que se adaptan a tu ritmo. Streetwear premium con un propósito que trasciende lo convencional.
          </p>
          <div class="btn-group">
            <button class="btn-elite-dark" id="go-products-3d">EXPLORAR AHORA</button>
          </div>
        </div>
      </div>

      <div class="visual-side">
        <div class="floating-wrapper">
          <img
            src={imgPolera.src}
            alt="Polera Misiones"
            class="floating-product"
            id="polo-dynamic-anim"
          />
          <div class="glow-backdrop"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .premium-showcase-v2 {
    background: #80b6b2; /* Keeping your brand teal */
    padding: 12rem 0;
    min-height: 90vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4rem;
    width: 100%;
  }

  .showcase-content-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: 6rem;
  }

  .eyebrow-accent {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: rgba(0,0,0,0.4);
    margin-bottom: 2rem;
    display: block;
  }

  .display-title {
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    font-weight: 950;
    line-height: 0.85;
    letter-spacing: -4px;
    color: #111;
    margin-bottom: 2.5rem;
  }

  .outline-display {
    color: transparent;
    -webkit-text-stroke: 1.5px #fff;
  }

  .description-text {
    font-size: 1.25rem;
    color: rgba(0,0,0,0.7);
    max-width: 450px;
    line-height: 1.6;
    margin-bottom: 4rem;
  }

  .btn-elite-dark {
    padding: 1.2rem 3.5rem;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 100px;
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.4s ease;
  }

  .btn-elite-dark:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    background: #000;
  }

  .visual-side {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .floating-wrapper {
    position: relative;
    width: 100%;
    max-width: 550px;
    z-index: 2;
  }

  .floating-product {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 50px 80px rgba(0, 0, 0, 0.2));
  }

  .glow-backdrop {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    z-index: -1;
  }

  @media (max-width: 1024px) {
    .premium-showcase-v2 {
      padding: 8rem 0;
    }
    .showcase-content-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .description-text {
      margin: 0 auto 4rem;
    }
    .floating-wrapper {
      max-width: 350px;
    }
    .container {
      padding: 0 1.5rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Staggered reveals
  gsap.from(".reveal-stagger > *", {
    scrollTrigger: {
      trigger: ".premium-showcase-v2",
      start: "top 80%",
    },
    y: 50,
    opacity: 0,
    duration: 1,
    stagger: 0.15,
    ease: "power4.out"
  });

  // Intense Product Parallax on Scroll
  gsap.to("#polo-dynamic-anim", {
    scrollTrigger: {
      trigger: ".premium-showcase-v2",
      start: "top bottom",
      end: "bottom top",
      scrub: 1,
    },
    yPercent: -20,
    rotation: 15,
    scale: 1.2,
    xPercent: 10,
    ease: "none",
  });

  // Continuous Floating Animation (Idle)
  gsap.to("#polo-dynamic-anim", {
    y: 20,
    duration: 2,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut"
  });

  // Smooth Button Scroll
  document.getElementById('go-products-3d')?.addEventListener('click', () => {
    const target = document.getElementById('polera-trigger');
    if (target) target.scrollIntoView({ behavior: 'smooth' });
  });
</script>

