---

---

<nav class="navbar" id="navbar">
  <div class="scroll-progress-container">
    <div class="scroll-progress-bar" id="progress-bar"></div>
  </div>

  <div class="nav-container">
    <div class="nav-left">
      <button class="menu-btn" id="menu-toggle" aria-label="Abrir Menú">
        <span class="line"></span>
        <span class="line"></span>
        <span class="line"></span>
      </button>
    </div>

    <div class="nav-center">
      <a href="/" class="logo">
        <img src="/logito.svg" alt="HDM STORE" class="logo-img" />
        <span class="logo-text">HDM STORE</span>
      </a>
    </div>

    <div class="nav-right">
      <button
        class="icon-btn nav-cart-trigger"
        id="nav-cart-btn"
        aria-label="Carrito"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"
          ></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"
          ></path></svg
        >
        <span class="cart-count">0</span>
      </button>
      <a href="/login" class="btn-login-mobile">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle
            cx="12"
            cy="7"
            r="4"></circle></svg
        >
      </a>
      <a href="/login" class="btn-login desktop-only">Iniciar Sesión</a>
    </div>
  </div>

  <!-- Mobile Overlay Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="menu-overlay" id="menu-close-area"></div>
    <div class="menu-content" id="menu-content">
      <div class="menu-header">
        <span class="menu-logo">HDM<span>STORE</span></span>
        <button class="close-btn" id="close-toggle">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="18" y1="6" x2="6" y2="18"></line><line
              x1="6"
              y1="6"
              x2="18"
              y2="18"></line></svg
          >
        </button>
      </div>

      <ul class="menu-links"></ul>
      <div class="menu-footer">
        <div class="menu-branding">
          <img src="/logo.png" alt="HDM STORE" class="menu-logo-img" />
        </div>
        <div class="inisio de sesion">
          <a href="/login" class="btn-login">Iniciar Sesión</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.5rem 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-progress-container {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: rgba(255, 255, 255, 0.1);
  }

  .scroll-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    transition: width 0.1s ease;
  }

  .navbar.scrolled {
    padding: 1rem 0;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .nav-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-left,
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
  }

  .nav-right {
    justify-content: flex-end;
  }

  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .logo-img {
    height: 35px;
    width: auto;
    transition: transform 0.3s ease;
  }

  .logo-text {
    font-family: var(--font-main);
    font-weight: 900;
    font-size: 1.3rem;
    letter-spacing: -1px;
    color: var(--color-text);
    margin-left: 12px;
  }

  .logo-text span {
    color: var(--color-primary);
  }

  .menu-btn {
    display: flex;
    flex-direction: column;
    gap: 7px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
  }

  .menu-btn span {
    width: 25px;
    height: 2px;
    background: var(--color-text);
    border-radius: 4px;
    transition: 0.3s;
  }

  .icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    position: relative;
    padding: 8px;
    border-radius: 50%;
    transition: background 0.3s;
  }

  .icon-btn:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .cart-count {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--color-primary);
    color: white;
    font-size: 0.7rem;
    font-weight: 800;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-login-mobile {
    display: none;
    color: var(--color-text);
    padding: 8px;
    border-radius: 50%;
    transition: background 0.3s;
  }

  .btn-login {
    padding: 0.8rem 2rem;
    border-radius: 50px;
    background: #111;
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-login:hover {
    background: var(--color-primary);
    transform: translateY(-2px);
  }

  /* Mobile Menu Overlay */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 2000;
    visibility: hidden;
    overflow: hidden;
  }

  .mobile-menu.open {
    visibility: visible;
  }

  .menu-overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    opacity: 0;
  }

  .menu-content {
    position: absolute;
    top: 0;
    right: -100%;
    width: 100%;
    height: 100%;
    background: #0a0a0a;
    color: white;
    padding: 6rem 2rem;
    display: flex;
    flex-direction: column;
  }

  .menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 5rem;
  }

  .menu-logo {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -1px;
  }

  .menu-logo span {
    color: var(--color-primary);
  }

  .close-btn {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
  }

  .menu-links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .menu-links a {
    font-size: 3.5rem;
    font-weight: 900;
    text-decoration: none;
    color: white;
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
  }

  .menu-links a span {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-primary);
    font-weight: 400;
  }

  .menu-footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .social-links {
    display: flex;
    gap: 2rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .social-links a {
    color: #555;
    text-decoration: none;
  }
  .social-links a:hover {
    color: white;
  }

  .menu-btn {
    display: none; /* Oculto en Desktop */
    flex-direction: column;
    gap: 7px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
  }

  .menu-copyright {
    font-size: 0.75rem;
    color: #333;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .nav-container {
      padding: 0 1.5rem;
    }
    .desktop-only {
      display: none;
    }
    .mobile-bottom-nav {
      display: flex;
    }
    .menu-btn {
      display: flex;
    } /* Mostrar solo en Móvil */
    .navbar {
      padding: 1rem 0;
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(15px);
    }
    .logo-text {
      font-size: 1.1rem;
    }
    .menu-links a {
      font-size: 2.2rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const menuToggle = document.getElementById("menu-toggle");
  const closeToggle = document.getElementById("close-toggle");
  const menuArea = document.getElementById("menu-close-area");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuContent = document.getElementById("menu-content");
  const navbar = document.getElementById("navbar");
  const progressBar = document.getElementById("progress-bar");

  // Scroll Progress and Navbar Scroll Effect
  window.addEventListener("scroll", () => {
    // Progress bar
    const winScroll =
      document.body.scrollTop || document.documentElement.scrollTop;
    const height =
      document.documentElement.scrollHeight -
      document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    if (progressBar) progressBar.style.width = scrolled + "%";

    // Navbar style
    if (window.scrollY > 50) {
      navbar?.classList.add("scrolled");
    } else {
      navbar?.classList.remove("scrolled");
    }
  });

  // GSAP Menu Animations
  const openMenu = () => {
    mobileMenu?.classList.add("open");

    const tl = gsap.timeline();
    tl.to(".menu-overlay", { opacity: 1, duration: 0.4 })
      .to(menuContent, { right: 0, duration: 0.8, ease: "expo.out" }, "-=0.2")
      .from(
        ".menu-item",
        {
          x: 50,
          opacity: 0,
          stagger: 0.1,
          duration: 0.8,
          ease: "power4.out",
        },
        "-=0.5",
      )
      .from(
        ".menu-footer",
        {
          y: 20,
          opacity: 0,
          duration: 0.6,
        },
        "-=0.4",
      );
  };

  const closeMenu = () => {
    const tl = gsap.timeline({
      onComplete: () => mobileMenu?.classList.remove("open"),
    });

    tl.to(".menu-item", { x: -20, opacity: 0, stagger: 0.05, duration: 0.4 })
      .to(
        menuContent,
        { right: "-100%", duration: 0.6, ease: "expo.in" },
        "-=0.2",
      )
      .to(".menu-overlay", { opacity: 0, duration: 0.3 }, "-=0.3");
  };

  menuToggle?.addEventListener("click", openMenu);
  closeToggle?.addEventListener("click", closeMenu);
  menuArea?.addEventListener("click", closeMenu);

  // Cart Triggers
  document.querySelectorAll(".nav-cart-trigger").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      document.getElementById("cart-drawer")?.classList.add("open");
    });
  });
</script>
