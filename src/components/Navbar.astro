<nav class="navbar" id="navbar">
  <div class="nav-container">
    <div class="nav-left">
      <button class="menu-btn" id="menu-toggle" aria-label="Abrir Menú">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <div class="nav-center">
      <a href="/" class="logo">
        <img src="/logito.svg" alt="HDM STORE" class="logo-img" />
        <span class="logo-text">HDM STORE</span>
      </a>
    </div>

    <div class="nav-right">
      <button class="icon-btn" id="nav-cart-btn" aria-label="Carrito">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"
          ></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"
          ></path></svg
        >
      </button>
      <a href="/login" class="btn-login">Iniciar Sesión</a>
    </div>
  </div>

  <!-- Mobile Overlay Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="menu-overlay" id="menu-close-area"></div>
    <div class="menu-content" id="menu-content">
      <div class="menu-header">
        <span class="menu-logo">MISIONES</span>
        <button class="close-btn" id="close-toggle">&times;</button>
      </div>
      <ul class="menu-links">
        <li><a href="/">Inicio</a></li>
        <li><a href="#threed-section">Colección 3D</a></li>
        <li><a href="#polera-showcase">Poleras</a></li>
        <li><a href="#">Accesorios</a></li>
        <li><a href="#">Contacto</a></li>
      </ul>
      <div class="menu-footer">
        <a href="/login" class="btn-comprar">Mi Cuenta</a>
      </div>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.5rem 0;
    transition: all 0.4s ease;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.1) 0%,
      transparent 100%
    );
  }

  .navbar.scrolled {
    padding: 1rem 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  .nav-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-left,
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
  }

  .nav-right {
    justify-content: flex-end;
  }

  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .logo-img {
    height: 32px; /* Reducido un poco para que combine con el texto */
    width: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  .logo-text {
    font-family: 'IBM Plex Sans', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: 2px;
    color: var(--color-text);
    margin-left: 10px;
    text-transform: uppercase;
  }

  .logo:hover .logo-img {
    transform: rotate(-10deg) scale(1.1);
  }

  .menu-btn {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 100;
  }

  .menu-btn span {
    width: 22px;
    height: 1.5px;
    background: var(--color-text);
    border-radius: 2px;
  }

  /* --- MOBILE MENU FIXED --- */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 2000;
    pointer-events: none; /* No bloquea el click si está cerrado */
    overflow: hidden;
    visibility: hidden;
  }

  .mobile-menu.open {
    pointer-events: all;
    visibility: visible;
  }

  .menu-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .mobile-menu.open .menu-overlay {
    opacity: 1;
  }

  .menu-content {
    position: absolute;
    top: 0;
    right: -100%; /* Empieza fuera de pantalla a la derecha */
    width: 450px;
    height: 100%;
    background: white;
    padding: 4rem;
    display: flex;
    flex-direction: column;
    transition: right 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: -20px 0 50px rgba(0, 0, 0, 0.2);
  }

  .mobile-menu.open .menu-content {
    right: 0; /* Desliza hacia adentro */
  }

  .menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4rem;
  }

  .menu-logo {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 2px;
  }

  .close-btn {
    font-size: 2.5rem;
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
  }

  .menu-links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .menu-links a {
    font-size: 2.5rem;
    font-weight: 800;
    text-decoration: none;
    color: var(--color-text);
    transition: 0.3s;
    display: block;
  }

  .menu-links a:hover {
    color: var(--color-primary);
    transform: translateX(15px);
  }

  .menu-footer {
    margin-top: auto;
  }

  .icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
  }

  .btn-login {
    padding: 0.7rem 1.8rem;
    border-radius: 50px;
    background: var(--color-primary);
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .nav-container {
      padding: 0 1.5rem;
    }
    .btn-login {
      display: none;
    }
    .logo {
      font-size: 1.4rem;
      letter-spacing: 2px;
    }
    .menu-content {
      width: 100%;
      padding: 3rem 2rem;
      right: -100%;
    }
    .menu-links a {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const menuToggle = document.getElementById("menu-toggle");
  const closeToggle = document.getElementById("close-toggle");
  const menuArea = document.getElementById("menu-close-area");
  const mobileMenu = document.getElementById("mobile-menu");
  const navbar = document.getElementById("navbar");

  // Control de Scroll para el fondo de la Navbar
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar?.classList.add("scrolled");
    } else {
      navbar?.classList.remove("scrolled");
    }
  });

  // Abrir Menú
  const openMenu = () => {
    mobileMenu?.classList.add("open");
    // Animación de entrada de los links
    gsap.from(".menu-links li", {
      x: 30,
      opacity: 0,
      stagger: 0.1,
      duration: 0.6,
      ease: "power3.out",
      delay: 0.4,
    });
  };

  // Cerrar Menú
  const closeMenu = () => {
    mobileMenu?.classList.remove("open");
  };

  menuToggle?.addEventListener("click", openMenu);
  closeToggle?.addEventListener("click", closeMenu);
  menuArea?.addEventListener("click", closeMenu);

  // Abrir carrito desde Navbar
  document.getElementById('nav-cart-btn')?.addEventListener('click', () => {
    document.getElementById('cart-drawer')?.classList.add('open');
  });
</script>
