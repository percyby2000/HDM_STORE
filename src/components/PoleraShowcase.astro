---
import imgPolos from "../assets/images/polos.jpeg";
import poloNegro from "../assets/polos/Negro.png";
import poloVino from "../assets/polos/Guinda.png";
import poloArena from "../assets/polos/Arena.png";
import poloMilitar from "../assets/polos/VerdeMilitar.png";
import poloAzulmarino from "../assets/polos/AzulMarino.png";
---

<section class="polera-showcase-premium" id="polera-trigger">
  <div class="scrolling-text-wrapper desktop-only">
    <div class="scrolling-text" id="bg-text-move">
      MISIONES • STREETWEAR • PREMIUM • QUALITY • FE •
    </div>
  </div>

  <div class="container">
    <div class="header-section animate-reveal-polera">
      <h2 class="title-main">
        LA ESENCIA DEL <span class="outline-text">ESTILO</span>
      </h2>
      <div class="subtitle-wrapper">
        <span class="line"></span>
        <p class="subtitle">COLECCIÓN MISIONES 2026</p>
        <span class="line"></span>
      </div>
    </div>

    <div class="showcase-visual animate-reveal-polera">
      <div class="image-container">
        <img
          src={imgPolos.src}
          alt="Colección completa Misiones"
          class="parallax-image"
        />
        <div class="glass-overlay"></div>
        <div class="floating-badge">NUEVA ERA</div>
      </div>
    </div>

    <div class="showcase-content">
      <div class="info-card animate-reveal-polera">
        <div class="offer-tag">OFERTA LIMITADA</div>
        <h3>MÁS QUE ROPA, <br/><span class="highlight">ES UN MENSAJE</span></h3>
        <p>Lleva la calidad premium a un precio sin precedentes. Algodón de alta densidad, bordado reforzado y un ajuste perfecto.</p>
        
        <div class="pricing-row">
          <div class="price-box">
            <span class="label">Ahora</span>
            <span class="value">S/ 30.00</span>
          </div>
          <div class="divider"></div>
          <div class="shipping-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            <span>Envío a todo Perú</span>
          </div>
        </div>

        <button
          class="btn-checkout-premium"
          id="buy-polera-loco"
        >
          <span>PEDIR POR WHATSAPP</span>
          <div class="btn-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .polera-showcase-premium {
    background-color: #000;
    color: #fff;
    padding: 10rem 0;
    position: relative;
    overflow: hidden;
  }

  .scrolling-text-wrapper {
    position: absolute;
    top: 15%;
    left: 0;
    width: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .scrolling-text {
    font-size: 15vw;
    font-weight: 950;
    color: rgba(255, 255, 255, 0.02);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: -0.5vw;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 10;
  }

  .header-section {
    text-align: center;
    margin-bottom: 5rem;
  }

  .title-main {
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 950;
    line-height: 0.9;
    letter-spacing: -4px;
    margin-bottom: 2rem;
  }

  .outline-text {
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.5);
  }

  .subtitle-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }

  .subtitle-wrapper .line {
    height: 1px;
    width: 60px;
    background: var(--color-primary);
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 4px;
    color: var(--color-primary);
  }

  .showcase-visual {
    width: 100%;
    margin-bottom: 6rem;
    border-radius: 2rem;
    overflow: hidden;
    box-shadow: 0 50px 100px rgba(0,0,0,0.5);
  }

  .image-container {
    position: relative;
    line-height: 0;
  }

  .parallax-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    transform: scale(1.1);
  }

  .glass-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.8));
  }

  .floating-badge {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: #fff;
    color: #000;
    padding: 0.8rem 2rem;
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 2px;
    border-radius: 4px;
  }

  .info-card {
    max-width: 800px;
    margin: 0 auto;
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(20px);
    padding: 5rem 4rem;
    border-radius: 3rem;
    border: 1px solid rgba(255,255,255,0.05);
    text-align: center;
  }

  .offer-tag {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: var(--color-primary);
    color: #fff;
    font-weight: 900;
    font-size: 0.7rem;
    letter-spacing: 2px;
    border-radius: 50px;
    margin-bottom: 2rem;
  }

  .info-card h3 {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .highlight { color: var(--color-primary); }

  .info-card p {
    font-size: 1.2rem;
    color: #888;
    line-height: 1.8;
    margin-bottom: 4rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4rem;
    margin-bottom: 5rem;
  }

  .price-box {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .price-box .label {
    font-size: 0.8rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .price-box .value {
    font-size: 3.5rem;
    font-weight: 950;
    color: #fff;
  }

  .pricing-row .divider {
    height: 40px;
    width: 1px;
    background: rgba(255,255,255,0.1);
  }

  .shipping-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: #55998a;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .btn-checkout-premium {
    width: 100%;
    max-width: 450px;
    background: #fff;
    color: #000;
    padding: 1.5rem 3rem;
    border: none;
    border-radius: 100px;
    font-weight: 900;
    font-size: 1.1rem;
    letter-spacing: 1px;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-checkout-premium:hover {
    background: var(--color-primary);
    color: #fff;
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 20px 40px rgba(85, 153, 138, 0.3);
  }

  @media (max-width: 768px) {
    .polera-showcase-premium {
      padding: 4rem 0;
    }
    .info-card {
      padding: 3rem 1.5rem;
      border-radius: 2rem;
    }
    .pricing-row {
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 3rem;
    }
    .price-box .value {
      font-size: 2.8rem;
    }
    .pricing-row .divider {
      display: none;
    }
    .btn-checkout-premium {
      padding: 1.2rem 2rem;
      font-size: 1rem;
      gap: 1rem;
    }
    .title-main {
      font-size: 3rem;
      letter-spacing: -2px;
    }
  }
</style>

<script define:vars={{ 
  imgNegro: poloNegro.src, 
  imgVino: poloVino.src, 
  imgArena: poloArena.src, 
  imgMilitar: poloMilitar.src, 
  imgAzul: poloAzulmarino.src 
}}>
  function attachPoleraListener() {
    const btn = document.getElementById("buy-polera-loco");
    if (!btn) return;
    
    btn.onclick = () => {
      if (window.openProductModal) {
        window.openProductModal({
          name: "Polo Colección Misiones",
          price: 30.00,
          image: imgNegro,
          colors: [
            { name: "Negro", hex: "#111", image: imgNegro },
            { name: "Arena", hex: "#C2B280", image: imgArena },
            { name: "Verde Militar", hex: "#4B5320", image: imgMilitar },
            { name: "Guinda", hex: "#800020", image: imgVino },
            { name: "Azul Marino", hex: "#1a2a40", image: imgAzul },
          ],
        });
      }
    };
  }
  
  attachPoleraListener();
  document.addEventListener('astro:after-swap', attachPoleraListener);
</script>
