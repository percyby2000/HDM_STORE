---
import videoSource from "../assets/videos/video 2.mp4";
---

<section class="cinematic-video-section" id="video-trigger">
  <div class="video-sticky-container">
    <div class="video-inner-frame" id="video-frame">
      <video autoplay muted loop playsinline class="hero-video">
        <source src={videoSource} type="video/mp4" />
      </video>
      
      <div class="video-content-overlay">
        <div class="text-reveal-container">
          <h2 class="video-title">DISEÑO QUE <br/><span class="outline-white">INSPIRA</span></h2>
          <p class="video-tagline">
            Calidad excepcional en cada costura. Streetwear con propósito diseñado para la eternidad.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cinematic-video-section {
    height: 130vh; /* Reduced from 150vh for a tighter feel */
    position: relative;
    background: #000;
  }

  .video-sticky-container {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .video-inner-frame {
    position: relative;
    width: 80vw;
    height: 60vh;
    border-radius: 40px;
    overflow: hidden;
    will-change: width, height, border-radius;
    box-shadow: 0 50px 100px rgba(0,0,0,0.5);
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.1);
  }

  .video-content-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.6) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    padding: 2rem;
  }

  .video-title {
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 950;
    line-height: 0.85;
    letter-spacing: -3px;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(40px);
  }

  .outline-white {
    color: transparent;
    -webkit-text-stroke: 1.5px #fff;
  }

  .video-tagline {
    font-size: 1.2rem;
    max-width: 500px;
    margin: 0 auto;
    color: rgba(255,255,255,0.8);
    opacity: 0;
    transform: translateY(20px);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .cinematic-video-section {
      height: 120vh; /* Even more compact on mobile */
    }
    .video-inner-frame {
      width: 85vw;
      height: 40vh; /* Reduced height from 50vh */
      border-radius: 20px;
    }
    .video-title {
      font-size: 2.8rem; /* Slightly smaller title */
    }
    .video-tagline {
      font-size: 1rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Video Frame Expansion
  gsap.to("#video-frame", {
    width: "100vw",
    height: "100vh",
    borderRadius: "0px",
    scrollTrigger: {
      trigger: ".cinematic-video-section",
      start: "top top",
      end: "center top",
      scrub: 1,
    }
  });

  // Text Reveal
  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: ".cinematic-video-section",
      start: "center center",
      end: "bottom top",
      toggleActions: "play none none reverse"
    }
  });

  tl.to(".video-title", {
    opacity: 1,
    y: 0,
    duration: 1,
    ease: "power4.out"
  })
  .to(".video-tagline", {
    opacity: 1,
    y: 0,
    duration: 1,
    ease: "power4.out"
  }, "-=0.6");
</script>

