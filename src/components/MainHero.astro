---
import poloNegro from "../assets/polos/polo-negro.png";
import poloVino from "../assets/polos/polo-vino.png";
import poloArena from "../assets/polos/polo_arena.png";
import poloMilitar from "../assets/polos/polo_militar.png";
import poloVerde from "../assets/polos/verde_oscuro.png";
---

<section class="main-hero">
  <!-- Social Icons Flotantes - Solo Desktop -->
  <div class="social-sidebar desktop-only">
    <a href="#" class="social-link"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a>
    <a href="#" class="social-link"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
    <a href="#" class="social-link"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v8M8 12h8"></path></svg></a>
  </div>

  <!-- Background Text Parallax -->
  <div class="hero-bg-text desktop-only" id="hero-bg-text">MISIONES</div>

  <div class="hero-container">
    <div class="product-side">
      <div class="image-wrapper hero-parallax-img">
        <img src={poloNegro.src} alt="Polo Negro" class="product-img active" id="img-negro" />
        <img src={poloVino.src} alt="Polo Vino" class="product-img" id="img-vino" />
        <img src={poloArena.src} alt="Polo Arena" class="product-img" id="img-arena" />
        <img src={poloMilitar.src} alt="Polo Militar" class="product-img" id="img-militar" />
        <img src={poloVerde.src} alt="Polo Verde" class="product-img" id="img-verde" />
      </div>

      <!-- ESTE SOLO SE VE EN MÓVIL (Bajo la imagen) -->
      <div class="color-picker-v2 mobile-only">
        <span class="label">Colores:</span>
        <div class="color-dots">
          <button class="dot active" data-color="negro" style="background-color: #1a1a1a;"></button>
          <button class="dot" data-color="vino" style="background-color: #55998a;"></button>
          <button class="dot" data-color="arena" style="background-color: #8bbdc4;"></button>
          <button class="dot" data-color="militar" style="background-color: #725a83;"></button>
        </div>
      </div>
    </div>

    <div class="content-side">
      <div class="text-content">
        <h1 class="main-title">
          <span class="dark-text">MISIONES</span> <br/> 
          <span class="highlight">POLOS</span>
        </h1>
        <p class="tagline">Un mundo de estilo <span class="bold">envolvente</span>, donde cada prenda cobra <span class="bold">vida</span>.</p>
        
        <div class="actions-row">
          <button class="btn-primary btn-comprar" id="hero-buy-btn">Comprar</button>
        </div>

        <!-- ESTE SOLO SE VE EN DESKTOP (A la derecha) -->
        <div class="color-picker-v2 desktop-only">
          <span class="label">Colores:</span>
          <div class="color-dots">
            <button class="dot active" data-color="negro" style="background-color: #1a1a1a;"></button>
            <button class="dot" data-color="vino" style="background-color: #55998a;"></button>
            <button class="dot" data-color="arena" style="background-color: #8bbdc4;"></button>
            <button class="dot" data-color="militar" style="background-color: #725a83;"></button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="code-icon desktop-only">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ddd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
  </div>
</section>

<style>
  .main-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: 80px;
    background: #fdfdfd;
    overflow: hidden;
  }

  .social-sidebar {
    position: fixed;
    left: 2rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex !important;
    flex-direction: column !important;
    align-items: center;
    gap: 2.5rem;
    z-index: 1000;
  }

  .social-sidebar::after {
    content: "";
    width: 1px;
    height: 60px;
    background: rgba(0, 0, 0, 0.1);
    margin-top: 1rem;
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 25vw;
    font-weight: 900;
    color: rgba(0, 0, 0, 0.02);
    z-index: 0;
    white-space: nowrap;
    pointer-events: none;
  }

  .hero-container {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 2rem;
    padding: 0 6rem;
    position: relative;
    z-index: 10;
  }

  .product-side {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .image-wrapper {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 1/1;
    position: relative;
  }

  .product-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-img.active { opacity: 1; }

  .main-title {
    font-size: clamp(4rem, 9vw, 7.5rem);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -4px;
    margin-bottom: 2rem;
    color: #111;
  }

  .highlight { color: var(--color-primary); }

  .tagline {
    font-size: 1.2rem;
    color: #666;
    margin-bottom: 3rem;
    max-width: 400px;
  }

  .btn-primary {
    padding: 1.2rem 3.5rem;
    background: #111;
    color: white;
    border-radius: 50px;
    border: none;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    transition: 0.4s;
  }

  .color-picker-v2 {
    margin-top: 4rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .color-picker-v2 .label { font-weight: 800; font-size: 1.1rem; }
  .color-dots { display: flex; gap: 1.2rem; }

  .dot {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 3px solid white;
    box-shadow: 0 0 0 1px #ddd;
    cursor: pointer;
    transition: 0.3s;
  }

  .dot.active { transform: scale(1.2); box-shadow: 0 0 0 2px var(--color-primary); }

  .code-icon {
    position: fixed;
    right: 3rem;
    bottom: 3rem;
    opacity: 0.5;
    z-index: 1000;
  }

  .mobile-only { 
    display: none !important; 
  }

  .desktop-only {
    display: flex !important;
  }

  @media (max-width: 1024px) {
    .desktop-only { display: none !important; }
    .mobile-only { display: flex !important; }
    
    .main-hero { padding-top: 100px; padding-bottom: 50px; }
    .hero-container { grid-template-columns: 1fr; text-align: center; padding: 0 1.5rem; gap: 1rem; }
    .image-wrapper { max-width: 320px; margin: 0 auto; }
    .main-title { font-size: 3.5rem; margin-top: 1rem; margin-bottom: 1.5rem; }
    .tagline { font-size: 1.1rem; margin: 0 auto 2.5rem; padding: 0 1rem; }
    .color-picker-v2 { margin-top: 2rem; flex-direction: column; gap: 1rem; }
    .btn-primary { width: 80%; margin: 0 auto; }
  }
</style>

<script>
  document.getElementById('hero-buy-btn')?.addEventListener('click', () => {
    document.getElementById('products')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
