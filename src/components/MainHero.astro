---
import poloNegro from "../assets/polos/Negro.png";
import poloVino from "../assets/polos/Guinda.png";
import poloArena from "../assets/polos/Arena.png";
import poloMilitar from "../assets/polos/VerdeMilitar.png";
import poloAzulmarino from "../assets/polos/AzulMarino.png";
---

<section class="main-hero" id="home">
  <!-- Social Icons -->
  <div class="social-sidebar desktop-only">
    <a href="#" class="social-link" aria-label="Facebook">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
        ></path></svg
      >
    </a>
    <a href="#" class="social-link" aria-label="Instagram">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
          d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
          x1="17.5"
          y1="6.5"
          x2="17.51"
          y2="6.5"></line></svg
      >
    </a>
  </div>

  <!-- Background Text -->
  <div class="hero-bg-text desktop-only" id="hero-bg-text">MISIONES</div>

  <div class="hero-container">
    <div class="product-side">
      <div class="image-wrapper hero-parallax-img" id="hero-image-container">
        <img
          src={poloNegro.src}
          alt="Polo Negro"
          class="product-img active"
          id="img-negro"
        />
        <img
          src={poloVino.src}
          alt="Polo Guinda"
          class="product-img"
          id="img-vino"
        />
        <img
          src={poloArena.src}
          alt="Polo Arena"
          class="product-img"
          id="img-arena"
        />
        <img
          src={poloMilitar.src}
          alt="Polo Militar"
          class="product-img"
          id="img-militar"
        />
        <img
          src={poloAzulmarino.src}
          alt="Polo Azul Marino"
          class="product-img"
          id="img-azulmarino"
        />
      </div>

      <!-- Mobile Picker -->
      <div class="color-picker-mobile mobile-only">
        <div class="color-dots">
          <button
            class="dot active"
            data-color="negro"
            style="background-color: #111;"></button>
          <button
            class="dot"
            data-color="vino"
            style="background-color: #5e1c1c;"></button>
          <button
            class="dot"
            data-color="arena"
            style="background-color: #d2b48c;"></button>
          <button
            class="dot"
            data-color="militar"
            style="background-color: #4b5320;"></button>
          <button
            class="dot"
            data-color="azulmarino"
            style="background-color: #1a2a40;"></button>
        </div>
      </div>
    </div>

    <div class="content-side">
      <div class="text-content reveal-hero">
        <h1 class="main-title">
          <span class="block-reveal">MISIONES</span>
        </h1>

        <div class="actions-row">
          <button class="btn-primary" id="hero-buy-btn">Ver Colección</button>
        </div>

        <div class="color-picker-desktop desktop-only">
          <span class="label">Explora colores:</span>
          <div class="color-dots">
            <button
              class="dot active"
              data-color="negro"
              style="background-color: #111;"></button>
            <button
              class="dot"
              data-color="vino"
              style="background-color: #5e1c1c;"></button>
            <button
              class="dot"
              data-color="arena"
              style="background-color: #d2b48c;"></button>
            <button
              class="dot"
              data-color="militar"
              style="background-color: #4b5320;"></button>
            <button
              class="dot"
              data-color="azulmarino"
              style="background-color: #1a2a40;"></button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .main-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: 80px;
    background: #fff;
    overflow: hidden;
  }

  .social-sidebar {
    position: fixed;
    left: 2rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    z-index: 100;
  }

  .social-link {
    color: #000;
    opacity: 0.5;
    transition: 0.3s;
  }
  .social-link:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 22vw;
    font-weight: 950;
    color: rgba(0, 0, 0, 0.03);
    z-index: 0;
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: -1.5vw;
    text-transform: uppercase;
  }

  .hero-container {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    padding: 0 4rem;
    position: relative;
    z-index: 10;
  }

  .product-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .image-wrapper {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 1/1;
    position: relative;
  }

  .product-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transform: translateX(30px) scale(0.95);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-img.active {
    opacity: 1;
    transform: translateX(0) scale(1);
  }

  .content-side {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .main-title {
    font-size: clamp(3.5rem, 8.5vw, 7rem);
    font-weight: 950;
    line-height: 0.85;
    letter-spacing: -4px;
    margin-bottom: 2rem;
    color: #000;
  }

  .highlight {
    color: var(--color-primary);
  }

  .tagline {
    font-size: 1.2rem;
    color: #444;
    margin-bottom: 3rem;
    max-width: 480px;
    line-height: 1.6;
    font-weight: 500;
  }

  .btn-primary {
    padding: 1.2rem 3.5rem;
    background: #000;
    color: #fff;
    border-radius: 100px;
    border: none;
    font-weight: 900;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-primary:hover {
    background: var(--color-primary);
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(85, 153, 138, 0.3);
  }

  .color-picker-desktop {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #999;
    font-weight: 700;
  }

  .color-dots {
    display: flex;
    gap: 1.2rem;
  }

  .dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 3px solid #fff;
    box-shadow: 0 0 0 1px #eee;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    transform: scale(1.2);
    box-shadow: 0 0 0 2px var(--color-primary);
  }

  .desktop-only {
    display: flex;
  }
  .mobile-only {
    display: none;
  }

  @media (max-width: 1024px) {
    .desktop-only {
      display: none !important;
    }
    .mobile-only {
      display: flex !important;
    }
    .main-hero {
      padding-top: 60px;
      padding-bottom: 40px;
    }
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 0 1.5rem;
      gap: 2rem;
    }
    .image-wrapper {
      max-width: 380px;
    }
    .main-title {
      font-size: clamp(3rem, 13vw, 4.5rem);
      letter-spacing: -2px;
    }
    .tagline {
      margin: 0 auto 2.5rem;
    }
    .btn-primary {
      width: 100%;
      max-width: 320px;
    }
    .color-picker-mobile {
      margin-top: 2rem;
      justify-content: center;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Robust reveal animation with state management
  const heroRevealTl = gsap.timeline({
    onComplete: () => {
      // Ensure everything is visible and clean after animation
      gsap.set(".reveal-hero > *", { clearProps: "all" });
    },
  });

  heroRevealTl.fromTo(
    ".reveal-hero > *",
    { y: 30, opacity: 0 },
    {
      y: 0,
      opacity: 1,
      duration: 1,
      stagger: 0.1,
      ease: "power4.out",
      delay: 0.5,
    },
  );

  // Background Text Parallax
  gsap.to("#hero-bg-text", {
    xPercent: -15,
    scrollTrigger: {
      trigger: ".main-hero",
      start: "top top",
      end: "bottom top",
      scrub: 1,
    },
  });

  // Image Parallax
  gsap.to(".hero-parallax-img", {
    y: -30,
    scrollTrigger: {
      trigger: ".main-hero",
      start: "top top",
      end: "bottom top",
      scrub: true,
    },
  });

  // Buy button scroll
  document.getElementById("hero-buy-btn")?.addEventListener("click", () => {
    const poleraEl = document.getElementById("polera-trigger");
    if (poleraEl) poleraEl.scrollIntoView({ behavior: "smooth" });
  });

  // Color selection
  document.querySelectorAll(".dot").forEach((dot) => {
    dot.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const color = target.dataset.color;
      document
        .querySelectorAll(".dot")
        .forEach((d) => d.classList.remove("active"));
      document
        .querySelectorAll(`.dot[data-color="${color}"]`)
        .forEach((d) => d.classList.add("active"));
      document
        .querySelectorAll(".product-img")
        .forEach((img) => img.classList.remove("active"));
      document.getElementById(`img-${color}`)?.classList.add("active");
    });
  });
</script>
